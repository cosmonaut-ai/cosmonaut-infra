# =============================================================================
# Cosmonaut Infra — Environment Variables
# =============================================================================
# Copy this file to .envrc and fill in the values.

# AWS CLI profile with permissions to manage the Cosmonaut infrastructure
AWS_PROFILE=cosmonaut

# Cloudflare API token for DNS management (zone edit permissions)
TF_VAR_cloudflare_api_token=your_cloudflare_api_token_here
